ngth=n_fft\n    )\n    magnitude = tf.abs(stft)\n\n    # Mel filterbank\n    mel_filterbank = tf.signal.linear_to_mel_weight_matrix(\n        num_mel_bins=n_mels,\n        num_spectrogram_bins=n_fft // 2 + 1,\n        sample_rate=sr,\n        lower_edge_hertz=0,\n        upper_edge_hertz=sr // 2,\n    )\n\n    mel_spec = tf.matmul(magnitude, mel_filterbank)\n\n    # log-mel\n    mel_spec_db = tf.math.log(mel_spec + 1e-6)\n\n    # normalize 0..1\n    mel_min = tf.reduce_min(mel_spec_db)\n    mel_max = tf.reduce_max(mel_spec_db)\n    mel_norm = (mel_spec_db - mel_min) / (mel_max - mel_min + 1e-8)\n\n    return mel_norm\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-19T09:06:56.396877Z","iopub.execute_input":"2025-12-19T09:06:56.397286Z","iopub.status.idle":"2025-12-19T09:06:56.402891Z","shell.execute_reply.started":"2025-12-19T09:06:56.397247Z","shell.execute_reply":"2025-12-19T09:06:56.402156Z"}},"outputs":[],"execution_count":22},{"cell_type":"code","source":"def load_audio(audio_path):\n    try:\n        audio, sr = librosa.load(audio_path, sr=16000)\n        return audio, sr\n    except Exception as e:\n        raise Exception(f\"Error loading audio {audio_path}: {str(e)}\")\n\ndef extract_mel_spectrogram(audio):\n    mel_spec = librosa.feature.melspectrogram(\n        y=audio,\n        sr=16000,\n        n_mels=80,\n        n_fft=1024,\n        hop_length=256\n    )\n\n    mel_spec_db = librosa.power_to_db(mel_spec, ref=np.max)\n\n    mel_spec_norm = (mel_spec_db - mel_spec_db.min()) / (mel_spec_db.max() - mel_spec_db.min() + 1e-8)\n\n    return mel_spec_norm.T  # (time, mel_bins)\n\ndef prepare_audio_features(audio):\n    mel_spec = extract_mel_spectrogram(audio)\n\n    # Correct number of frames for 5 seconds\n    MAX_FRAMES = int((5 * 16000) // 256)  # = 625 frames\n\n    if mel_spec.shape[0] > MAX_FRAMES:\n        mel_spec = mel_spec[:MAX_FRAMES, :]\n    else:\n        pad_width = MAX_FRAMES - mel_spec.shape[0]\n        mel_spec = np.pad(mel_spec, ((0, pad_width), (0, 0)), mode='constant')\n\n    return mel_spec.astype(np.float32)\n\ndef process_audio(audio_path):\n    audio, sr = load_audio(audio_path)\n    features = prepare_audio_features(audio)\n    return features\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-19T09:06:56.404420Z","iopub.execute_input":"2025-12-19T09:06:56.404650Z","iopub.status.idle":"2025-12-19T09:06:56.417927Z","shell.execute_reply.started":"2025-12-19T09:06:56.404629Z","shell.execute_reply":"2025-12-19T09:06:56.417328Z"}},"outputs":[],"execution_count":23},{"cell_type":"code","source":"audio = []\ntext_seq = []\n\nfor i in range(len(dataframe)):\n    # os.path.join(audio_paths, dataframe['file_name'][0])\n    audio_path = os.path.join(audio_paths, dataframe['file_name'][i])\n    text = dataframe['sentence'][i]\n    seq = tokenizer.encode(text)\n\n    # seq = tokenizer.texts_to_sequences([text])         # shape (1, L)\n    seq = seq\n    seq_padded = pad_sequences([seq], maxlen=int((5 * 16000) // 256), padding='post', truncating='post')[0]\n\n    features = process_audio(audio_path=audio_path)\n\n    audio.append(features)\n    text_seq.append(seq_padded)\n\n# Later, when batching:\naudio = np.array(audio)       # (batch, 625, 80)\ntext_seq = np.array(text_seq) # (batch, 625)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2025-12-19T09:06:56.418872Z","iopub.execute_input":"2025-12-19T09:06:56.419098Z","iopub.status.idle":"2025-12-19T09:09:16.618031Z","shell.execute_reply.started":"2025-12-19T09:06:56.419078Z","shell.execute_reply":"2025-12-19T09:09:16.617124Z"}},"outputs":[],"execution_count":24},{"cell_type":"code","source":"class TextEncoder(tf.keras.Model):\n  def __init__(self, vocab_size, embedding_dim, hidden_dim):\n    super().__init__()\n    self.embedding = tf.keras.layers.Embedding(vocab_size, embedding_dim)\n    self.lstm = tf.keras.layers.Bidirectional(\n        tf.keras.layers.LSTM(hidden_dim, return_sequences=False))\